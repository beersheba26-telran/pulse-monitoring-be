{
  "name": "pulse-monitoring-be",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js + TypeScript backend starter using tsx",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "seed:db": "tsx seed_db.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.893.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "knex": "^3.2.10",
    "mongodb": "^7.3.0",
    "morgan": "^1.11.0",
    "pg": "^8.21.0"
  }
}
